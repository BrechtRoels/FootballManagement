# --- Database ---
# Local development (Docker Postgres from docker-compose.yml):
DATABASE_URL=postgresql+psycopg://football:football@localhost:5432/football
#
# Production (Supabase): use the "Connection string" from your Supabase project
# settings -> Database -> Connection pooling (port 6543, "Transaction" mode).
# Keep the psycopg driver and add ?sslmode=require, e.g.:
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- Security ---
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-please-generate-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- First admin (created by seed script) ---
FIRST_ADMIN_EMAIL=admin@ksvjabbeke.be
FIRST_ADMIN_PASSWORD=ChangeMe123!
FIRST_ADMIN_NAME=KSV Jabbeke Secretariaat

# --- CORS (comma-separated origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Web Push (VAPID) ---
# Generate a keypair with:  python -m app.scripts.gen_vapid
# VAPID_SUBJECT must be a mailto: or https: URL (a contact for push services).
# Leave the keys empty to disable push (the app still works without it).
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY_B64=
